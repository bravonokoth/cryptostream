# ── CoinGecko ──────────────────────────────────
# Get free key at: coingecko.com → API → Demo plan
COINGECKO_API_KEY=your_coingecko_demo_key_here

# ── Neon PostgreSQL ────────────────────────────
# Get from: neon.tech → your project → connection string
NEON_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
NEON_DB_PASSWORD=your_neon_password_here

# ── Kafka (Confluent Cloud) ────────────────────
# Get from: Confluent Cloud → Cluster → Clients → Node.js
KAFKA_BOOTSTRAP_SERVERS=your-cluster.confluent.cloud:9092
KAFKA_API_KEY=your_confluent_api_key
KAFKA_API_SECRET=your_confluent_api_secret

# ── Schema Registry (Confluent Cloud) ──────────
# Get from: Confluent Cloud → Schema Registry tab
SCHEMA_REGISTRY_URL=https://your-registry.confluent.cloud
SCHEMA_REGISTRY_API_KEY=your_sr_api_key
SCHEMA_REGISTRY_API_SECRET=your_sr_api_secret

# ── App settings ───────────────────────────────
NODE_ENV=development
POLL_INTERVAL_MS=300000
LOG_LEVEL=info
METRICS_PORT=9464