# ══════════════════════════════════════════════════════════════════
#  CryptoStream — Environment Variables
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to Git.
# ══════════════════════════════════════════════════════════════════

# ── CoinGecko ──────────────────────────────────────────────────
COINGECKO_API_KEY=your_coingecko_api_key_here

# ── Neon PostgreSQL (remote, used by ingestor + dbt) ───────────
NEON_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
NEON_POOLER_URL=postgresql://user:password@pooler-host/dbname?sslmode=require
NEON_DB_PASSWORD=your_neon_password

# ── Local PostgreSQL (used by Airflow metadata) ─────────────────
POSTGRES_DB=airflow
POSTGRES_USER=airflow
POSTGRES_PASSWORD=change_me_strong_password

# ── Kafka ───────────────────────────────────────────────────────
# Inside Docker containers use the internal listener
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
# From your HOST machine (e.g. when running Node outside Docker)
# KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_INTERNAL_SERVERS=kafka:9092
KAFKA_API_KEY=
KAFKA_API_SECRET=

# ── Schema Registry ─────────────────────────────────────────────
SCHEMA_REGISTRY_URL=http://schema-registry:8081
SCHEMA_REGISTRY_API_KEY=
SCHEMA_REGISTRY_API_SECRET=

# ── Ingestor app settings ───────────────────────────────────────
NODE_ENV=production
POLL_INTERVAL_MS=300000       # 5 minutes between CoinGecko polls
LOG_LEVEL=info
METRICS_PORT=9464

# ── Airflow ─────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=change_me_generate_a_real_fernet_key
AIRFLOW_SECRET_KEY=change_me_airflow_webserver_secret
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@cryptostream.local

# ── dbt / Neon connection (read by profiles.yml) ─────────────────
DBT_NEON_HOST=ep-your-neon-endpoint.us-east-1.aws.neon.tech
DBT_NEON_USER=neondb_owner
DBT_NEON_DB=neondb
DBT_NEON_PORT=5432
# DBT_NEON_PASSWORD reuses NEON_DB_PASSWORD — no need to duplicate

# ── Grafana ─────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password
